{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native / Expo",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "allowJs": true,
    "noEmit": true
  }
}
