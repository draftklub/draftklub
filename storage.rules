rules_version = '2';

// Firebase Storage rules pro projeto DraftKlub.
//
// Padrão de segurança:
// - read: avatares são públicos (URLs aparecem em /perfil, /home, sidebar)
// - write: cada user só escreve sob seu próprio path `users/{uid}/...`
// - default: tudo bloqueado
//
// Deploy: `firebase deploy --only storage` ou via Console (Build →
// Storage → Rules → cole o conteúdo abaixo). Pode usar a API REST
// também via firebaserules.googleapis.com.

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
