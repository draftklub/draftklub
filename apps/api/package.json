{
  "name": "@draftklub/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@draftklub/shared-types": "workspace:*",
    "@draftklub/sport-strategies": "workspace:^",
    "@fastify/helmet": "^13.0.2",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.0",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/nestjs": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "firebase-admin": "^13.8.0",
    "nestjs-pino": "^4.3.0",
    "nestjs-zod": "^5.3.0",
    "passport": "^0.7.0",
    "pg": "^8.14.1",
    "pino-http": "^10.4.0",
    "prisma": "^7.6.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@draftklub/eslint-config": "workspace:*",
    "@draftklub/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.25.0",
    "fastify": "^5.8.5",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.0"
  }
}
