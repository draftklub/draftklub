NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://api:SENHA@127.0.0.1:5433/draftklub
LOG_LEVEL=debug
OTEL_ENABLED=false
OTEL_SERVICE_NAME=draftklub-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# CORS_ORIGINS — CSV de origens permitidas. Se omitido, defaults sensatos
# por NODE_ENV (dev -> localhost:3001; staging -> staging.draftklub.com;
# production -> draftklub.com[.br] + www).
# Override exemplo: CORS_ORIGINS=http://localhost:3001,http://localhost:3002
