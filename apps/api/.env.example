NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://api:SENHA@127.0.0.1:5433/draftklub
LOG_LEVEL=debug
OTEL_ENABLED=false
OTEL_SERVICE_NAME=draftklub-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# CORS_ORIGINS — CSV de origens permitidas. Se omitido, defaults sensatos
# por NODE_ENV (dev -> localhost:3001; staging -> staging.draftklub.com;
# production -> draftklub.com[.br] + www).
# Override exemplo: CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Sprint D PR3 — email transacional (Resend, https://resend.com).
# Sem RESEND_API_KEY, EmailService cai em modo log-only (não envia
# emails reais; útil pra dev local).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM="DraftKlub <noreply@draftklub.com>"
# APP_BASE_URL — base pros links nos emails (defaults pro draftklub.com em prod).
# APP_BASE_URL=https://draftklub.com
