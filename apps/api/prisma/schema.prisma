model Space {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId      String    @map("klub_id") @db.Uuid
  name        String
  // ex: "Quadra 1", "Quadra Central", "Sala A"
  type        SpaceType   @default(court)
  sportCode   String?     @map("sport_code")
  surface     SpaceSurface?
  indoor      Boolean   @default(false)
  hasLighting Boolean   @default(false) @map("has_lighting")
  maxPlayers  Int       @default(4)     @map("max_players")
  description String?
  amenities   Json      @default("{}")
  status      SpaceStatus @default(active)

  slotGranularityMinutes     Int      @default(30) @map("slot_granularity_minutes")
  // 15-180, múltiplo de 15 (validação Zod + check constraint)
  slotDefaultDurationMinutes Int      @default(60) @map("slot_default_duration_minutes")
  bookingActive              Boolean  @default(true) @map("booking_active")

  hourBands                  Json     @default("[]") @map("hour_bands")
  // [{ type: 'off_peak'|'regular'|'prime', startHour, endHour, daysOfWeek,
  //    durationByMatchType: { singles?, doubles? } }]
  allowedMatchTypes          Json     @default("[\"singles\",\"doubles\"]") @map("allowed_match_types")
  // ['singles', 'doubles'] | ['singles'] | ['doubles']

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid

  tournamentMatches TournamentMatch[]
  bookings          Booking[]
  bookingSeries     BookingSeries[]
  createdBy         User? @relation("SpaceCreatedBy", fields: [createdById], references: [id])
  updatedBy         User? @relation("SpaceUpdatedBy", fields: [updatedById], references: [id])

  @@map("spaces")
