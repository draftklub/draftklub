generator client {
  provider        = "prisma-client-js"
previewFeatures = []
}

datasource db {
  provider = "postgresql"
  schemas  = ["identity", "audit", "klub", "space", "sports", "booking"]
}

// ═══════════════════════════════════════════════════════════════
// AUDIT — schema compartilhado, usado por todos os módulos
// ═══════════════════════════════════════════════════════════════

model OutboxEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType     String    @map("event_type")
  eventVersion  Int       @default(1) @map("event_version")
  payload       Json
  occurredAt    DateTime  @default(now()) @map("occurred_at") @db.Timestamptz
  status        OutboxEventStatus @default(pending)
  attempts      Int               @default(0)
  lastError     String?           @map("last_error")
  sentAt        DateTime? @map("sent_at") @db.Timestamptz
  correlationId String?   @map("correlation_id")

  @@index([occurredAt], map: "idx_outbox_pending")
  @@map("outbox_events")
  @@schema("audit")
}

// ═══════════════════════════════════════════════════════════════
// IDENTITY — usuários, memberships, papéis escopados
// ═══════════════════════════════════════════════════════════════

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid    String?   @unique @map("firebase_uid")
  // nullable: guests nao tem Firebase
  email          String    @unique
  phone          String?
  fullName       String    @map("full_name")
  birthDate      DateTime? @map("birth_date") @db.Date
  avatarUrl      String?   @map("avatar_url")
  gender         UserGender?
  // 'male' | 'female' | 'undisclosed'
  city           String?
  state          String?   @db.Char(2)
  cep            String?   @db.Char(8)
  addressStreet  String?   @map("address_street")
  addressNumber  String?   @map("address_number")
  addressComplement     String?   @map("address_complement")
  addressNeighborhood   String?   @map("address_neighborhood")
  latitude       Float?
  longitude      Float?
  // Geocoded via CEP (BrasilAPI v2). Fallback pra "próximos a mim"
  // quando user nega geolocation do browser.

  kind            UserKind    @default(regular)
  documentNumber  String?     @map("document_number")
  documentType    DocumentType? @map("document_type")

  consentGivenAt DateTime? @map("consent_given_at") @db.Timestamptz
  consentVersion String?   @map("consent_version")

  notificationPrefs Json @default("{}") @map("notification_prefs")
  // Shape: { email: { enrollment, booking, tournament, invitation, announcement } }
  // Defaults interpretados client-side: missing key → true.
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  memberships     Membership[]
  roleAssignments RoleAssignment[]
  rankingEntries    PlayerRankingEntry[] @relation("PlayerEntries")
  matchesSubmitted  MatchResult[]        @relation("MatchesSubmitted")
  tournamentEntries TournamentEntry[]    @relation("TournamentEntries")
  responsibleForBookings Booking[]       @relation("ResponsibleMember")
  sportEnrollments       PlayerSportEnrollment[]
  membershipRequests          MembershipRequest[] @relation("UserMembershipRequests")
  decidedMembershipRequests   MembershipRequest[] @relation("DecidedMembershipRequests")

  // ─── Back-relations de auditoria (DB-3) ──────────────────────
  membershipsCreated          Membership[]              @relation("MembershipCreatedBy")
  rolesGranted                RoleAssignment[]          @relation("RoleGrantedBy")
  klubsCreated                Klub[]                    @relation("KlubCreatedBy")
  klubsReviewDecided          Klub[]                    @relation("KlubReviewDecidedBy")
  klubsUpdated                Klub[]                    @relation("KlubUpdatedBy")
  klubConfigsCreated          KlubConfig[]              @relation("KlubConfigCreatedBy")
  klubConfigsUpdated          KlubConfig[]              @relation("KlubConfigUpdatedBy")
  sportProfilesAdded          KlubSportProfile[]        @relation("SportProfileAddedBy")
  sportProfilesUpdated        KlubSportProfile[]        @relation("SportProfileUpdatedBy")
  enrollmentsApproved         PlayerSportEnrollment[]   @relation("EnrollmentApprovedBy")
  enrollmentsSuspended        PlayerSportEnrollment[]   @relation("EnrollmentSuspendedBy")
  enrollmentsCancelled        PlayerSportEnrollment[]   @relation("EnrollmentCancelledBy")
  enrollmentsUpdated          PlayerSportEnrollment[]   @relation("EnrollmentUpdatedBy")
  rankingsCreated             KlubSportRanking[]        @relation("RankingCreatedBy")
  rankingsUpdated             KlubSportRanking[]        @relation("RankingUpdatedBy")
  matchResultsConfirmed       MatchResult[]             @relation("MatchResultConfirmedBy")
  matchResultsValidated       MatchResult[]             @relation("MatchResultValidatedBy")
  pointsSchemasCreated        RankingPointsSchema[]     @relation("PointsSchemaCreatedBy")
  pointsSchemasUpdated        RankingPointsSchema[]     @relation("PointsSchemaUpdatedBy")
  tournamentsCreated          Tournament[]              @relation("TournamentCreatedBy")
  tournamentsUpdated          Tournament[]              @relation("TournamentUpdatedBy")
  tournamentsCancelled        Tournament[]              @relation("TournamentCancelledBy")
  tournamentCategoriesCreated TournamentCategory[]      @relation("TournamentCategoryCreatedBy")
  tournamentCategoriesUpdated TournamentCategory[]      @relation("TournamentCategoryUpdatedBy")
  tournamentMatchesUpdated    TournamentMatch[]         @relation("TournamentMatchUpdatedBy")
  tournamentEntriesApproved   TournamentEntry[]         @relation("TournamentEntryApprovedBy")
  tournamentEntriesMoved      TournamentEntry[]         @relation("TournamentEntryMovedBy")
  klubRequestsReviewed        KlubRequest[]             @relation("KlubRequestReviewedBy")
  spacesCreated               Space[]                   @relation("SpaceCreatedBy")
  spacesUpdated               Space[]                   @relation("SpaceUpdatedBy")
  bookingsPrimaryPlayer       Booking[]                 @relation("BookingPrimaryPlayer")
  bookingsCreated             Booking[]                 @relation("BookingCreatedBy")
  bookingsApproved            Booking[]                 @relation("BookingApprovedBy")
  bookingsRejected            Booking[]                 @relation("BookingRejectedBy")
  bookingsCancelled           Booking[]                 @relation("BookingCancelledBy")
  bookingsUpdated             Booking[]                 @relation("BookingUpdatedBy")
  bookingSeriesPrimaryPlayer  BookingSeries[]           @relation("BookingSeriesPrimaryPlayer")
  bookingSeriesCreated        BookingSeries[]           @relation("BookingSeriesCreatedBy")
  bookingSeriesCancelled      BookingSeries[]           @relation("BookingSeriesCancelledBy")
  bookingSeriesUpdated        BookingSeries[]           @relation("BookingSeriesUpdatedBy")

  @@map("users")
  @@schema("identity")
}

model Membership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  klubId    String    @map("klub_id") @db.Uuid
  status    MembershipStatus @default(active)
  type      MembershipType   @default(member)
  joinedAt  DateTime         @default(now()) @map("joined_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdById String? @map("created_by_id") @db.Uuid

  user      User  @relation(fields: [userId], references: [id])
  klub      Klub  @relation("KlubMemberships", fields: [klubId], references: [id], map: "memberships_klub_id_fkey")
  createdBy User? @relation("MembershipCreatedBy", fields: [createdById], references: [id])

  @@unique([userId, klubId])
  @@map("memberships")
  @@schema("identity")
}

// Sprint C PR1 — pedido de entrada em Klub privado (accessMode='private').
// Usuário submete com mensagem (ex: nº de matrícula); KLUB_ADMIN do
// Klub aprova/rejeita. Aprovação cria Membership + RoleAssignment PLAYER
// (na mesma tx). Unique parcial garante 1 pendente por (klub, user) —
// histórico de rejected/cancelled fica disponível.
model MembershipRequest {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId          String    @map("klub_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  status          MembershipRequestStatus @default(pending)
  message         String
  attachmentUrl   String?   @map("attachment_url")
  decisionAt      DateTime? @map("decision_at") @db.Timestamptz
  decidedById     String?   @map("decided_by_id") @db.Uuid
  rejectionReason String?   @map("rejection_reason")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  klub      Klub @relation("KlubMembershipRequests", fields: [klubId], references: [id], onDelete: Cascade)
  user      User @relation("UserMembershipRequests", fields: [userId], references: [id])
  decidedBy User? @relation("DecidedMembershipRequests", fields: [decidedById], references: [id])

  @@map("membership_requests")
  @@schema("klub")
}

model RoleAssignment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  /// Role do user. Sprint Polish PR-J1 reestruturou:
  ///   PLATFORM_OWNER   — singleton (max 1 row, partial unique index)
  ///   PLATFORM_ADMIN   — quota max 3 (app-level)
  ///   KLUB_ADMIN       — singleton por Klub (partial unique on scope_klub_id)
  ///   KLUB_ASSISTANT   — vários por Klub
  ///   SPORT_COMMISSION — torneios/ranking/match (scoped por Klub + sport)
  ///   SPORT_STAFF      — operação dia-a-dia (scoped por Klub + sport)
  ///   PLAYER           — default
  role         String
  scopeKlubId  String?   @map("scope_klub_id") @db.Uuid
  scopeSportId String?   @map("scope_sport_id") @db.Uuid
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  grantedBy    String?   @map("granted_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  user         User  @relation(fields: [userId], references: [id])
  grantedByUser User? @relation("RoleGrantedBy", fields: [grantedBy], references: [id])

  @@map("role_assignments")
  @@schema("identity")
}

// ─── Feature gates ────────────────────────────────────────────
// tier: 'free' | 'premium' | 'disabled'
// 'free'     → todos os usuários autenticados
// 'premium'  → usuários de Klubs com plano pago (non-trial)
// 'disabled' → ninguém (hard-off independente de enabled)

model Feature {
  id          String   @id
  displayName String   @map("display_name")
  description String?
  tier        FeatureTier @default(free)
  enabled     Boolean     @default(true)
  rolloutPct  Int      @default(100) @map("rollout_pct")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  audits FeatureAudit[]

  @@map("features")
  @@schema("identity")
}

model FeatureAudit {
  id        BigInt   @id @default(autoincrement())
  featureId String   @map("feature_id")
  changedBy String   @map("changed_by")
  field     String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz

  feature Feature @relation(fields: [featureId], references: [id])

  @@index([featureId], map: "idx_features_audit_feature_id")
  @@map("features_audit")
  @@schema("audit")
}

/// Sprint N batch 3 — cache de Idempotency-Key (padrão Stripe).
/// Mutations (POST/PATCH/DELETE) com `Idempotency-Key` header têm
/// (status, body) cacheados por 24h scoped por user. Retry com mesma
/// key+payload retorna cached; payload diferente retorna 422.
model IdempotencyKey {
  key          String
  userId       String   @map("user_id") @db.Uuid
  method       String
  path         String
  requestHash  String   @map("request_hash")
  statusCode   Int      @map("status_code")
  responseBody Json     @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  expiresAt    DateTime @map("expires_at") @db.Timestamptz

  @@id([userId, key])
  @@index([expiresAt], map: "idempotency_keys_expires_at_idx")
  @@map("idempotency_keys")
  @@schema("audit")
}

/// Sprint M batch 7 — audit log estruturado pra eventos de segurança.
/// Registra role grants/revokes, klub admin transfers, aprovações
/// admin, cancelamentos, deleções. Cobre LGPD Art. 37 + forensics.
model SecurityEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Quem fez a ação. Null = sistema/cron/migration.
  actorId    String?  @map("actor_id") @db.Uuid
  /// Tipo do recurso afetado: 'role'|'klub'|'booking'|'tournament'|'user'|'membership'|...
  targetType String   @map("target_type")
  /// PK do recurso afetado quando aplicável.
  targetId   String?  @map("target_id") @db.Uuid
  /// Ação canônica: 'role.granted', 'klub.admin.transferred', 'tournament.cancelled', etc.
  action     String
  /// Estado anterior (parcial — só campos relevantes).
  before     Json?
  /// Estado novo (parcial — só campos relevantes).
  after      Json?
  /// Contexto extra: ip, user_agent, motivo, escopo, etc.
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([actorId, createdAt(sort: Desc)], map: "security_events_actor_id_created_at_idx")
  @@index([targetType, targetId, createdAt(sort: Desc)], map: "security_events_target_type_target_id_created_at_idx")
  @@index([action, createdAt(sort: Desc)], map: "security_events_action_created_at_idx")
  @@map("security_events")
  @@schema("audit")
}

// ═══════════════════════════════════════════════════════════════
// KLUB
// ═══════════════════════════════════════════════════════════════

model Klub {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // ─── Identidade ───────────────────────────────────────────
  name        String
  slug        String    @unique
  description String?
  avatarUrl   String?   @map("avatar_url")
  coverUrl    String?   @map("cover_url")
  /// Abreviação curta pra UI compacta (ex: "PAC" pra Paissandu).
  abbreviation String?  @db.VarChar(10)
  /// Nome popular/comumente chamado (ex: "Paissandú").
  commonName  String?   @map("common_name") @db.VarChar(100)

  // ─── Tipo ─────────────────────────────────────────────────
  type        KlubType  @default(sports_club)

  // ─── Localização ──────────────────────────────────────────
  country     String    @default("BR")
  state       String?
  city        String?
  address     String?
  zipCode     String?   @map("zip_code")
  timezone    String    @default("America/Sao_Paulo")
  latitude    Decimal?  @db.Decimal(10, 8)
  longitude   Decimal?  @db.Decimal(11, 8)
  // Endereço granular (Sprint D PR1). `address` legacy permanece pra
  // não quebrar dados existentes; novos cadastros populam os granulares.
  addressStreet       String? @map("address_street")
  addressNumber       String? @map("address_number")
  addressComplement   String? @map("address_complement")
  addressNeighborhood String? @map("address_neighborhood")
  addressSource       String? @map("address_source")
  // 'cnpj_lookup' | 'manual' — origem dos campos de endereço.
  // Anti-divergência: campos auto-preenchidos via Receita ficam
  // read-only no UI até user explicitamente "Editar manualmente".

  // ─── Contato ──────────────────────────────────────────────
  email       String?
  phone       String?
  website     String?

  // ─── Comodidades (JSONB flexível) ─────────────────────────
  amenities   Json      @default("{}")
  // {"parking": true, "locker": false, "wifi": true, ...}

  // ─── Plano e billing ──────────────────────────────────────
  plan        KlubPlan   @default(trial)
  status      KlubStatus @default(trial)
  trialEndsAt DateTime? @map("trial_ends_at") @db.Timestamptz

  // ─── Limites operacionais ─────────────────────────────────
  maxMembers  Int       @default(50)    @map("max_members")
  maxSports   Int       @default(2)     @map("max_sports")
  maxCourts   Int       @default(3)     @map("max_courts")
  txFeeRate   Decimal   @default(0.025) @map("tx_fee_rate") @db.Decimal(5, 4)

  // ─── Filiais ──────────────────────────────────────────────
  parentKlubId  String?  @map("parent_klub_id") @db.Uuid
  isGroup       Boolean  @default(false) @map("is_group")
  billingKlubId String?  @map("billing_klub_id") @db.Uuid
  // null = o próprio Klub é responsável pelo billing

  // ─── Discovery + privacy (Sprint B) ────────────────────────
  // (latitude/longitude já existem acima; Sprint B+1 vai geocodificar
  //  via CEP+address e popular esses campos.)
  discoverable Boolean        @default(false)
  accessMode   KlubAccessMode @default(public) @map("access_mode")
  cep          String? @db.Char(8)
  // CEP do Klub. Source pra geocoding lat/lng (Sprint B+1).

  // ─── Onboarding ───────────────────────────────────────────
  onboardingSource KlubOnboardingSource @default(self_service) @map("onboarding_source")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid

  // ─── Review administrativo (Sprint D PR1) ─────────────────
  // Ortogonal a `status` (trial/active/...) e a `kycStatus`. Klub
  // só vira visível em /klubs/discover e /k/:slug quando
  // reviewStatus='approved'. Plano comercial não muda.
  reviewStatus           KlubReviewStatus @default(pending) @map("review_status")
  reviewDecisionAt       DateTime?        @map("review_decision_at") @db.Timestamptz
  reviewDecidedById      String?   @map("review_decided_by_id") @db.Uuid
  reviewRejectionReason  String?   @map("review_rejection_reason")

  // ─── Auditoria ────────────────────────────────────────────
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  legal              KlubLegal?
  config             KlubConfig?
  sportProfiles      KlubSportProfile[]  @relation("KlubSportProfiles")
  sportInterests     KlubSportInterest[] @relation("KlubSportInterests")
  media              KlubMedia[]
  memberships        Membership[]        @relation("KlubMemberships")
  membershipRequests MembershipRequest[] @relation("KlubMembershipRequests")
  bookings           Booking[]           @relation("BookingKlub")
  createdBy          User?               @relation("KlubCreatedBy", fields: [createdById], references: [id])
  reviewDecidedBy    User?               @relation("KlubReviewDecidedBy", fields: [reviewDecidedById], references: [id])
  updatedBy          User?               @relation("KlubUpdatedBy", fields: [updatedById], references: [id])

  @@map("klubs")
  @@schema("klub")
}

model KlubLegal {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId              String          @unique @map("klub_id") @db.Uuid
  entityType          KlubEntityType? @map("entity_type")
  documentEncrypted   String?         @map("document_encrypted")
  documentIv          String?         @map("document_iv")
  documentHint        String?         @map("document_hint")
  legalName           String?         @map("legal_name")
  kycStatus           KlubKycStatus   @default(pending) @map("kyc_status")
  cnpjStatus          String?         @map("cnpj_status")
  cnpjStatusCheckedAt DateTime?       @map("cnpj_status_checked_at") @db.Timestamptz
  cnpjLookupData      Json?           @map("cnpj_lookup_data")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  klub                Klub            @relation(fields: [klubId], references: [id], onDelete: Cascade)

  @@map("klub_legal")
  @@schema("klub")
}

model KlubConfig {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId  String  @unique @map("klub_id") @db.Uuid

  // ─── Política de reserva (granular) ───────────────────────
  accessMode              KlubConfigAccessMode @default(members_only) @map("access_mode")

  bookingModes            Json                 @default("[\"direct\"]") @map("booking_modes")
  // ['direct', 'staff_approval', 'staff_only'] — modos podem combinar

  cancellationMode        KlubCancellationMode @default(with_deadline) @map("cancellation_mode")

  agendaVisibility        KlubAgendaVisibility @default(public) @map("agenda_visibility")

  // DEPRECATED: mantido por compat (backfill em init_booking popula accessMode)
  bookingPolicy           KlubConfigAccessMode @default(members_only) @map("booking_policy")

  // ─── Política de cancelamento ─────────────────────────────
  cancellationWindowHours Int     @default(24)  @map("cancellation_window_hours")
  cancellationFeePercent  Decimal @default(0)   @map("cancellation_fee_percent") @db.Decimal(5, 2)

  // ─── Política de no-show ──────────────────────────────────
  noShowFeeEnabled  Boolean @default(false) @map("no_show_fee_enabled")
  noShowFeeAmount   Decimal @default(0)     @map("no_show_fee_amount") @db.Decimal(10, 2)

  // ─── Pagamento ────────────────────────────────────────────
  gatewayAccountId String? @map("gateway_account_id")

  // ─── Horários de funcionamento ────────────────────────────
  openingHour Int     @default(6)             @map("opening_hour")
  closingHour Int     @default(23)            @map("closing_hour")
  openDays    String  @default("1,2,3,4,5,6,7") @map("open_days")

  maxRecurrenceMonths Int @default(3) @map("max_recurrence_months")

  // ─── Extensão de booking ──────────────────────────────────
  extensionMode       KlubExtensionMode @default(disabled) @map("extension_mode")

  // ─── Convidados + integracao com torneio ──────────────────
  guestsAddedBy                 KlubGuestsAddedBy          @default(both) @map("guests_added_by")
  tournamentBookingConflictMode KlubTournamentConflictMode @default(staff_decides) @map("tournament_booking_conflict_mode")

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid

  klub       Klub  @relation(fields: [klubId], references: [id])
  createdBy  User? @relation("KlubConfigCreatedBy", fields: [createdById], references: [id])
  updatedBy  User? @relation("KlubConfigUpdatedBy", fields: [updatedById], references: [id])

  @@map("klub_configs")
  @@schema("klub")
}

model KlubSportProfile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId        String    @map("klub_id") @db.Uuid
  sportCode     String    @map("sport_code")

  name          String?
  description   String?
  coverUrl      String?   @map("cover_url")

  defaultRatingEngine   RatingEngineType      @default(elo) @map("default_rating_engine")
  defaultRatingConfig   Json                  @default("{}") @map("default_rating_config")
  defaultInitialRating  Int                   @default(1000) @map("default_initial_rating")

  status        KlubSportProfileStatus @default(active)
  addedAt       DateTime               @default(now()) @map("added_at") @db.Timestamptz
  addedById     String?   @map("added_by_id") @db.Uuid
  updatedAt     DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  updatedById   String?   @map("updated_by_id") @db.Uuid
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  klub       Klub         @relation("KlubSportProfiles", fields: [klubId], references: [id])
  sport      SportCatalog @relation(fields: [sportCode], references: [code])
  rankings   KlubSportRanking[]    @relation("RankingProfiles")
  pointsSchemas  RankingPointsSchema[] @relation("PointsSchemas")
  tournaments    Tournament[]          @relation("Tournaments")
  playerSportEnrollments PlayerSportEnrollment[]
  addedBy    User? @relation("SportProfileAddedBy", fields: [addedById], references: [id])
  updatedBy  User? @relation("SportProfileUpdatedBy", fields: [updatedById], references: [id])

  @@unique([klubId, sportCode])
  @@map("klub_sport_profiles")
  @@schema("klub")
}

model PlayerSportEnrollment {
