model Tournament {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubSportId             String    @map("klub_sport_id") @db.Uuid
  rankingId               String    @map("ranking_id") @db.Uuid

  name                    String
  description             String?
  coverUrl                String?   @map("cover_url")

  format                  TournamentFormat              @default(knockout)
  hasPrequalifiers        Boolean                       @default(false) @map("has_prequalifiers")
  prequalifierBordersPerFrontier Int?                   @map("prequalifier_borders_per_frontier")

  registrationApproval    TournamentRegistrationApproval @default(auto) @map("registration_approval")
  registrationFee         Decimal?  @map("registration_fee") @db.Decimal(10, 2)

  registrationOpensAt     DateTime  @map("registration_opens_at") @db.Timestamptz
  registrationClosesAt    DateTime  @map("registration_closes_at") @db.Timestamptz
  drawDate                DateTime  @map("draw_date") @db.Timestamptz
  prequalifierStartDate   DateTime? @map("prequalifier_start_date") @db.Timestamptz
  prequalifierEndDate     DateTime? @map("prequalifier_end_date") @db.Timestamptz
  mainStartDate           DateTime  @map("main_start_date") @db.Timestamptz
  mainEndDate             DateTime? @map("main_end_date") @db.Timestamptz

  scheduleConfig          Json      @default("{}") @map("schedule_config")

  tieBreakRule            Json?     @default("[\"wins\",\"head_to_head\",\"set_diff\",\"game_diff\"]") @map("tie_break_rule")
  groupsConfig            Json?     @map("groups_config")

  status                  TournamentStatus              @default(draft)
  currentPhase            String?                       @map("current_phase")

  resultReportingMode     TournamentResultReportingMode @default(committee_only) @map("result_reporting_mode")

  pointsApplied           Boolean   @default(false) @map("points_applied")
  pointsAppliedAt         DateTime? @map("points_applied_at") @db.Timestamptz

  createdById             String?   @map("created_by_id") @db.Uuid
  updatedById             String?   @map("updated_by_id") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  cancelledAt             DateTime? @map("cancelled_at") @db.Timestamptz
  cancelledById           String?   @map("cancelled_by_id") @db.Uuid
  cancellationReason      String?   @map("cancellation_reason")
  deletedAt               DateTime? @map("deleted_at") @db.Timestamptz

  klubSport               KlubSportProfile @relation("Tournaments", fields: [klubSportId], references: [id])
  ranking                 KlubSportRanking @relation("TournamentRankings", fields: [rankingId], references: [id])
  categories    TournamentCategory[]
  entries       TournamentEntry[]
  matches       TournamentMatch[]
  matchResults  MatchResult[] @relation("TournamentMatchResults")
  createdBy     User?         @relation("TournamentCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?         @relation("TournamentUpdatedBy", fields: [updatedById], references: [id])
  cancelledBy   User?         @relation("TournamentCancelledBy", fields: [cancelledById], references: [id])

  @@map("tournaments")
  @@schema("klub")
}

model TournamentCategory {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId      String  @map("tournament_id") @db.Uuid

  name              String
  order             Int     @default(0)

  maxPlayers        Int?    @map("max_players")
