generator client {
  provider        = "prisma-client-js"
previewFeatures = []
}

datasource db {
  provider = "postgresql"
  schemas  = ["identity", "audit", "klub", "space", "sports", "booking"]
}

// ═══════════════════════════════════════════════════════════════
// AUDIT — schema compartilhado, usado por todos os módulos
// ═══════════════════════════════════════════════════════════════

model OutboxEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType     String    @map("event_type")
  eventVersion  Int       @default(1) @map("event_version")
  payload       Json
  occurredAt    DateTime  @default(now()) @map("occurred_at") @db.Timestamptz
  status        String    @default("pending")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error")
  sentAt        DateTime? @map("sent_at") @db.Timestamptz
  correlationId String?   @map("correlation_id")

  @@index([occurredAt], map: "idx_outbox_pending")
  @@map("outbox_events")
  @@schema("audit")
}

// ═══════════════════════════════════════════════════════════════
// IDENTITY — usuários, memberships, papéis escopados
// ═══════════════════════════════════════════════════════════════

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid    String?   @unique @map("firebase_uid")
  // nullable: guests nao tem Firebase
  email          String    @unique
  phone          String?
  fullName       String    @map("full_name")
  birthDate      DateTime? @map("birth_date") @db.Date
  avatarUrl      String?   @map("avatar_url")
  gender         String?
  // 'male' | 'female' | 'undisclosed'
  city           String?
  state          String?   @db.Char(2)
  cep            String?   @db.Char(8)
  addressStreet  String?   @map("address_street")
  addressNumber  String?   @map("address_number")
  addressComplement     String?   @map("address_complement")
  addressNeighborhood   String?   @map("address_neighborhood")
  latitude       Float?
  longitude      Float?
  // Geocoded via CEP (BrasilAPI v2). Fallback pra "próximos a mim"
  // quando user nega geolocation do browser.

  kind            String    @default("regular")
  // 'regular' | 'guest'
  documentNumber  String?   @map("document_number")
  // CPF/RG/passport (sem encryption no MVP)
  documentType    String?   @map("document_type")
  // 'cpf' | 'rg' | 'passport' | 'other'

  consentGivenAt DateTime? @map("consent_given_at") @db.Timestamptz
  consentVersion String?   @map("consent_version")

  notificationPrefs Json @default("{}") @map("notification_prefs")
  // Shape: { email: { enrollment, booking, tournament, invitation, announcement } }
  // Defaults interpretados client-side: missing key → true.
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  memberships     Membership[]
  roleAssignments RoleAssignment[]
  rankingEntries    PlayerRankingEntry[] @relation("PlayerEntries")
  matchesSubmitted  MatchResult[]        @relation("MatchesSubmitted")
  tournamentEntries TournamentEntry[]    @relation("TournamentEntries")
  responsibleForBookings Booking[]       @relation("ResponsibleMember")
  sportEnrollments       PlayerSportEnrollment[]

  @@map("users")
  @@schema("identity")
}

model Membership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  klubId    String    @map("klub_id") @db.Uuid
  status    String    @default("active")
  type      String    @default("member")
  joinedAt  DateTime  @default(now()) @map("joined_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])
  klub Klub @relation("KlubMemberships", fields: [klubId], references: [id], map: "memberships_klub_id_fkey")

  @@unique([userId, klubId])
  @@map("memberships")
  @@schema("identity")
}

model RoleAssignment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  role         String
  scopeKlubId  String?   @map("scope_klub_id") @db.Uuid
  scopeSportId String?   @map("scope_sport_id") @db.Uuid
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  grantedBy    String?   @map("granted_by") @db.Uuid

  user User @relation(fields: [userId], references: [id])

  @@map("role_assignments")
  @@schema("identity")
}

// ═══════════════════════════════════════════════════════════════
// KLUB
// ═══════════════════════════════════════════════════════════════

model Klub {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // ─── Identidade ───────────────────────────────────────────
  name        String
  slug        String    @unique
  description String?
  avatarUrl   String?   @map("avatar_url")
  coverUrl    String?   @map("cover_url")

  // ─── Tipo ─────────────────────────────────────────────────
  type        String    @default("sports_club")
  // sports_club | condo | school | public_space | academy | individual

  // ─── Dados legais ─────────────────────────────────────────
  entityType          String?   @map("entity_type")   // pj | pf
  documentEncrypted   String?   @map("document_encrypted")
  documentHint        String?   @map("document_hint") // últimos 4 dígitos
  documentIv          String?   @map("document_iv")   // IV do AES-GCM
  legalName           String?   @map("legal_name")
  kycStatus           String    @default("pending") @map("kyc_status")
  // pending | approved | rejected

  // ─── Localização ──────────────────────────────────────────
  country     String    @default("BR")
  state       String?
  city        String?
  address     String?
  zipCode     String?   @map("zip_code")
  timezone    String    @default("America/Sao_Paulo")
  latitude    Decimal?  @db.Decimal(10, 8)
  longitude   Decimal?  @db.Decimal(11, 8)

  // ─── Contato ──────────────────────────────────────────────
  email       String?
  phone       String?
  website     String?

  // ─── Comodidades (JSONB flexível) ─────────────────────────
  amenities   Json      @default("{}")
  // {"parking": true, "locker": false, "wifi": true, ...}

  // ─── Plano e billing ──────────────────────────────────────
  plan        String    @default("trial")
  // trial | starter | pro | elite | enterprise
  status      String    @default("trial")
  // trial | active | suspended | churned | pending_payment
  trialEndsAt DateTime? @map("trial_ends_at") @db.Timestamptz

  // ─── Limites operacionais ─────────────────────────────────
  maxMembers  Int       @default(50)    @map("max_members")
  maxSports   Int       @default(2)     @map("max_sports")
  maxCourts   Int       @default(3)     @map("max_courts")
  txFeeRate   Decimal   @default(0.025) @map("tx_fee_rate") @db.Decimal(5, 4)

  // ─── Filiais ──────────────────────────────────────────────
  parentKlubId  String?  @map("parent_klub_id") @db.Uuid
  isGroup       Boolean  @default(false) @map("is_group")
  billingKlubId String?  @map("billing_klub_id") @db.Uuid
  // null = o próprio Klub é responsável pelo billing

  // ─── Discovery + privacy (Sprint B) ────────────────────────
  // (latitude/longitude já existem acima; Sprint B+1 vai geocodificar
  //  via CEP+address e popular esses campos.)
  discoverable Boolean @default(false)
  // true → aparece em GET /klubs/discover. Opt-in pelo Klub Admin.
  accessMode   String  @default("public") @map("access_mode")
  // 'public' (qualquer um entra direto via klub.join_via_link) |
  // 'private' (precisa MembershipRequest aprovado — Sprint C)
  cep          String? @db.Char(8)
  // CEP do Klub. Source pra geocoding lat/lng (Sprint B+1).

  // ─── Onboarding ───────────────────────────────────────────
  onboardingSource String @default("self_service") @map("onboarding_source")
  // self_service | sales_led
  createdById String?   @map("created_by_id") @db.Uuid

  // ─── Auditoria ────────────────────────────────────────────
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  config         KlubConfig?
  sportProfiles  KlubSportProfile[]  @relation("KlubSportProfiles")
  sportInterests KlubSportInterest[] @relation("KlubSportInterests")
  media          KlubMedia[]
  memberships    Membership[] @relation("KlubMemberships")

  @@map("klubs")
  @@schema("klub")
}

model KlubConfig {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId  String  @unique @map("klub_id") @db.Uuid

  // ─── Política de reserva (granular) ───────────────────────
  accessMode              String   @default("members_only") @map("access_mode")
  // 'public' | 'members_only'

  bookingModes            Json     @default("[\"direct\"]") @map("booking_modes")
  // ['direct', 'staff_approval', 'staff_only'] — modos podem combinar

  cancellationMode        String   @default("with_deadline") @map("cancellation_mode")
  // 'free' | 'with_deadline' | 'staff_only'

  agendaVisibility        String   @default("public") @map("agenda_visibility")
  // 'public' | 'private'

  // DEPRECATED: mantido por compat (backfill em init_booking popula accessMode)
  bookingPolicy           String   @default("members_only") @map("booking_policy")

  // ─── Política de cancelamento ─────────────────────────────
  cancellationWindowHours Int     @default(24)  @map("cancellation_window_hours")
  cancellationFeePercent  Decimal @default(0)   @map("cancellation_fee_percent") @db.Decimal(5, 2)

  // ─── Política de no-show ──────────────────────────────────
  noShowFeeEnabled  Boolean @default(false) @map("no_show_fee_enabled")
  noShowFeeAmount   Decimal @default(0)     @map("no_show_fee_amount") @db.Decimal(10, 2)

  // ─── Pagamento ────────────────────────────────────────────
  gatewayAccountId String? @map("gateway_account_id")

  // ─── Horários de funcionamento ────────────────────────────
  openingHour Int     @default(6)             @map("opening_hour")
  closingHour Int     @default(23)            @map("closing_hour")
  openDays    String  @default("1,2,3,4,5,6,7") @map("open_days")

  maxRecurrenceMonths Int @default(3) @map("max_recurrence_months")

  // ─── Extensão de booking ──────────────────────────────────
  extensionMode       String   @default("disabled") @map("extension_mode")
  // 'disabled' | 'player' | 'staff_approval' | 'staff_only'

  // ─── Convidados + integracao com torneio ──────────────────
  guestsAddedBy                 String   @default("both") @map("guests_added_by")
  // 'player' | 'staff' | 'both'

  tournamentBookingConflictMode String   @default("staff_decides") @map("tournament_booking_conflict_mode")
  // 'block_avulso' | 'auto_cancel_avulso' | 'staff_decides'

  klub  Klub  @relation(fields: [klubId], references: [id])

  @@map("klub_configs")
  @@schema("klub")
}

model KlubSportProfile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId        String    @map("klub_id") @db.Uuid
  sportCode     String    @map("sport_code")

  name          String?
  description   String?
  coverUrl      String?   @map("cover_url")

  defaultRatingEngine   String  @default("elo") @map("default_rating_engine")
  defaultRatingConfig   Json    @default("{}") @map("default_rating_config")
  defaultInitialRating  Int     @default(1000) @map("default_initial_rating")

  status        String    @default("active")
  addedAt       DateTime  @default(now()) @map("added_at") @db.Timestamptz
  addedById     String?   @map("added_by_id") @db.Uuid

  klub   Klub         @relation("KlubSportProfiles", fields: [klubId], references: [id])
  sport  SportCatalog @relation(fields: [sportCode], references: [code])
  rankings KlubSportRanking[] @relation("RankingProfiles")
  pointsSchemas  RankingPointsSchema[] @relation("PointsSchemas")
  tournaments    Tournament[]          @relation("Tournaments")
  playerSportEnrollments PlayerSportEnrollment[]

  @@unique([klubId, sportCode])
  @@map("klub_sport_profiles")
  @@schema("klub")
}

model PlayerSportEnrollment {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  klubSportProfileId  String    @map("klub_sport_profile_id") @db.Uuid

  status              String    @default("pending")
  // 'pending' | 'active' | 'suspended' | 'cancelled'

  enrolledAt          DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz
  approvedById        String?   @map("approved_by_id") @db.Uuid
  approvedAt          DateTime? @map("approved_at") @db.Timestamptz

  suspendedAt         DateTime? @map("suspended_at") @db.Timestamptz
  suspendedById       String?   @map("suspended_by_id") @db.Uuid
  suspensionReason    String?   @map("suspension_reason")

  cancelledAt         DateTime? @map("cancelled_at") @db.Timestamptz
  cancelledById       String?   @map("cancelled_by_id") @db.Uuid

  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  user                User              @relation(fields: [userId], references: [id])
  klubSportProfile    KlubSportProfile  @relation(fields: [klubSportProfileId], references: [id])

  @@unique([userId, klubSportProfileId])
  @@index([userId, status])
  @@index([klubSportProfileId, status])
  @@map("player_sport_enrollments")
  @@schema("klub")
}

// ═══════════════════════════════════════════════════════════════
// RANKING
// ═══════════════════════════════════════════════════════════════

model KlubSportRanking {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubSportId     String    @map("klub_sport_id") @db.Uuid

  name            String
  type            String    @default("singles")
  gender          String?
  ageMin          Int?      @map("age_min")
  ageMax          Int?      @map("age_max")

  ratingEngine    String    @default("elo") @map("rating_engine")
  ratingConfig    Json      @default("{}") @map("rating_config")
  initialRating   Int       @default(1000) @map("initial_rating")

  includesCasualMatches     Boolean   @default(true) @map("includes_casual_matches")
  includesTournamentMatches Boolean   @default(true) @map("includes_tournament_matches")
  includesTournamentPoints  Boolean   @default(false) @map("includes_tournament_points")

  orderBy                   String    @default("rating") @map("order_by")
  combinedWeight            Json?     @map("combined_weight")

  windowType                String    @default("all_time") @map("window_type")
  windowSize                Int?      @map("window_size")
  windowStartDate           DateTime? @map("window_start_date") @db.Timestamptz

  active          Boolean   @default(true)
  seasonId        String?   @map("season_id")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  klubSport       KlubSportProfile @relation("RankingProfiles", fields: [klubSportId], references: [id])
  entries         PlayerRankingEntry[]
  matches         MatchResult[]
  tournaments     Tournament[] @relation("TournamentRankings")

  @@map("klub_sport_rankings")
  @@schema("klub")
}

model PlayerRankingEntry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rankingId       String    @map("ranking_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid

  rating          Int       @default(1000)
  ratingSource    String    @default("initial") @map("rating_source")

  wins            Int       @default(0)
  losses          Int       @default(0)
  draws           Int       @default(0)
  gamesPlayed     Int       @default(0) @map("games_played")

  lastPlayedAt    DateTime? @map("last_played_at") @db.Timestamptz
  lastRatingChange Int      @default(0) @map("last_rating_change")

  position        Int?

  tournamentPoints        Int       @default(0) @map("tournament_points")
  lastTournamentAppliedAt DateTime? @map("last_tournament_applied_at") @db.Timestamptz

  active          Boolean   @default(true)
  joinedAt        DateTime  @default(now()) @map("joined_at") @db.Timestamptz

  ranking         KlubSportRanking @relation(fields: [rankingId], references: [id])
  user            User             @relation("PlayerEntries", fields: [userId], references: [id])

  @@unique([rankingId, userId])
  @@map("player_ranking_entries")
  @@schema("klub")
}

model MatchResult {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rankingId       String    @map("ranking_id") @db.Uuid

  player1Id       String    @map("player1_id") @db.Uuid
  player2Id       String    @map("player2_id") @db.Uuid

  winnerId        String?   @map("winner_id") @db.Uuid
  score           String?

  status          String    @default("pending_confirmation")

  submittedById   String    @map("submitted_by_id") @db.Uuid
  confirmedById   String?   @map("confirmed_by_id") @db.Uuid
  confirmedAt     DateTime? @map("confirmed_at") @db.Timestamptz

  validatedById   String?   @map("validated_by_id") @db.Uuid
  validatedAt     DateTime? @map("validated_at") @db.Timestamptz

  disputeReason   String?   @map("dispute_reason")

  player1RatingBefore Int?  @map("player1_rating_before")
  player2RatingBefore Int?  @map("player2_rating_before")
  player1RatingAfter  Int?  @map("player1_rating_after")
  player2RatingAfter  Int?  @map("player2_rating_after")
  ratingDelta1        Int?  @map("rating_delta1")
  ratingDelta2        Int?  @map("rating_delta2")

  playedAt        DateTime  @default(now()) @map("played_at") @db.Timestamptz
  spaceId         String?   @map("space_id") @db.Uuid

  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  source              String    @default("casual")
  tournamentId        String?   @map("tournament_id") @db.Uuid
  tournamentMatchId   String?   @map("tournament_match_id") @db.Uuid
  phase               String?
  bracketPosition     String?   @map("bracket_position")
  isWalkover          Boolean   @default(false) @map("is_walkover")

  ranking         KlubSportRanking @relation(fields: [rankingId], references: [id])
  submittedBy     User             @relation("MatchesSubmitted", fields: [submittedById], references: [id])
  tournament      Tournament?      @relation("TournamentMatchResults", fields: [tournamentId], references: [id])
  tournamentMatch TournamentMatch? @relation("TournamentMatchResult")

  @@index([tournamentId])
  @@index([source])
  @@map("match_results")
  @@schema("klub")
}

model KlubSportInterest {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId    String   @map("klub_id") @db.Uuid
  sportName String   @map("sport_name")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  klub  Klub  @relation("KlubSportInterests", fields: [klubId], references: [id])

  @@map("klub_sport_interests")
  @@schema("klub")
}

// ═══════════════════════════════════════════════════════════════
// COMPETITION — pontuação reutilizável e torneios
// ═══════════════════════════════════════════════════════════════

model RankingPointsSchema {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubSportId     String   @map("klub_sport_id") @db.Uuid

  name            String
  description     String?

  points          Json     @default("{}")

  active          Boolean  @default(true)
  createdById     String?  @map("created_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt      @map("updated_at") @db.Timestamptz

  klubSport       KlubSportProfile     @relation("PointsSchemas", fields: [klubSportId], references: [id])
  categories      TournamentCategory[]

  @@map("ranking_points_schemas")
  @@schema("klub")
}

model Tournament {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubSportId             String    @map("klub_sport_id") @db.Uuid
  rankingId               String    @map("ranking_id") @db.Uuid

  name                    String
  description             String?
  coverUrl                String?   @map("cover_url")

  format                  String    @default("knockout")
  hasPrequalifiers        Boolean   @default(false) @map("has_prequalifiers")
  prequalifierBordersPerFrontier Int? @map("prequalifier_borders_per_frontier")

  registrationApproval    String    @default("auto") @map("registration_approval")
  registrationFee         Decimal?  @map("registration_fee") @db.Decimal(10, 2)

  registrationOpensAt     DateTime  @map("registration_opens_at") @db.Timestamptz
  registrationClosesAt    DateTime  @map("registration_closes_at") @db.Timestamptz
  drawDate                DateTime  @map("draw_date") @db.Timestamptz
  prequalifierStartDate   DateTime? @map("prequalifier_start_date") @db.Timestamptz
  prequalifierEndDate     DateTime? @map("prequalifier_end_date") @db.Timestamptz
  mainStartDate           DateTime  @map("main_start_date") @db.Timestamptz
  mainEndDate             DateTime? @map("main_end_date") @db.Timestamptz

  scheduleConfig          Json      @default("{}") @map("schedule_config")

  tieBreakRule            Json?     @default("[\"wins\",\"head_to_head\",\"set_diff\",\"game_diff\"]") @map("tie_break_rule")
  groupsConfig            Json?     @map("groups_config")

  status                  String    @default("draft")
  currentPhase            String?   @map("current_phase")

  resultReportingMode     String    @default("committee_only") @map("result_reporting_mode")

  pointsApplied           Boolean   @default(false) @map("points_applied")
  pointsAppliedAt         DateTime? @map("points_applied_at") @db.Timestamptz

  createdById             String?   @map("created_by_id") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  cancelledAt             DateTime? @map("cancelled_at") @db.Timestamptz
  cancelledById           String?   @map("cancelled_by_id") @db.Uuid
  cancellationReason      String?   @map("cancellation_reason")

  klubSport               KlubSportProfile @relation("Tournaments", fields: [klubSportId], references: [id])
  ranking                 KlubSportRanking @relation("TournamentRankings", fields: [rankingId], references: [id])
  categories              TournamentCategory[]
  entries                 TournamentEntry[]
  matches                 TournamentMatch[]
  matchResults            MatchResult[] @relation("TournamentMatchResults")

  @@map("tournaments")
  @@schema("klub")
}

model TournamentCategory {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId      String  @map("tournament_id") @db.Uuid

  name              String
  order             Int     @default(0)

  maxPlayers        Int?    @map("max_players")
  minRatingExpected Int?    @map("min_rating_expected")
  maxRatingExpected Int?    @map("max_rating_expected")

  pointsSchemaId    String  @map("points_schema_id") @db.Uuid

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt      @map("updated_at") @db.Timestamptz

  tournament        Tournament          @relation(fields: [tournamentId], references: [id])
  pointsSchema      RankingPointsSchema @relation(fields: [pointsSchemaId], references: [id])
  entries           TournamentEntry[]
  matches           TournamentMatch[]

  @@unique([tournamentId, name])
  @@unique([tournamentId, order])
  @@map("tournament_categories")
  @@schema("klub")
}

model TournamentMatch {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId        String    @map("tournament_id") @db.Uuid
  categoryId          String    @map("category_id") @db.Uuid

  phase               String
  round               Int
  bracketPosition     String    @map("bracket_position")
  slotTop             Int       @map("slot_top")
  slotBottom          Int       @map("slot_bottom")

  player1Id           String?   @map("player1_id") @db.Uuid
  player2Id           String?   @map("player2_id") @db.Uuid

  seed1               Int?
  seed2               Int?
  isBye               Boolean   @default(false) @map("is_bye")

  nextMatchId         String?   @map("next_match_id") @db.Uuid
  nextMatchSlot       String?   @map("next_match_slot")

  status              String    @default("pending")
  winnerId            String?   @map("winner_id") @db.Uuid
  matchResultId       String?   @map("match_result_id") @db.Uuid @unique

  matchKind                     String    @default("main") @map("match_kind")
  prequalifierFrontierUpper     String?   @map("prequalifier_frontier_upper")
  prequalifierFrontierLower     String?   @map("prequalifier_frontier_lower")
  prequalifierPairIndex         Int?      @map("prequalifier_pair_index")

  tbdPlayer1Source              String?   @map("tbd_player1_source")
  tbdPlayer1PrequalifierMatchRef String?  @map("tbd_player1_prequalifier_ref") @db.Uuid
  tbdPlayer1Label               String?   @map("tbd_player1_label")

  tbdPlayer2Source              String?   @map("tbd_player2_source")
  tbdPlayer2PrequalifierMatchRef String?  @map("tbd_player2_prequalifier_ref") @db.Uuid
  tbdPlayer2Label               String?   @map("tbd_player2_label")

  spaceId             String?   @map("space_id") @db.Uuid
  scheduleWarning     String?   @map("schedule_warning")

  scheduledFor        DateTime? @map("scheduled_for") @db.Timestamptz
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  tournament          Tournament          @relation(fields: [tournamentId], references: [id])
  category            TournamentCategory  @relation(fields: [categoryId], references: [id])
  space               Space?              @relation(fields: [spaceId], references: [id])
  nextMatch           TournamentMatch?    @relation("BracketProgression", fields: [nextMatchId], references: [id])
  previousMatches     TournamentMatch[]   @relation("BracketProgression")
  matchResult         MatchResult?        @relation("TournamentMatchResult", fields: [matchResultId], references: [id])
  tbdPlayer1Prequalifier TournamentMatch? @relation("TbdPlayer1Ref", fields: [tbdPlayer1PrequalifierMatchRef], references: [id])
  tbdPlayer1DependentMatches TournamentMatch[] @relation("TbdPlayer1Ref")
  tbdPlayer2Prequalifier TournamentMatch? @relation("TbdPlayer2Ref", fields: [tbdPlayer2PrequalifierMatchRef], references: [id])
  tbdPlayer2DependentMatches TournamentMatch[] @relation("TbdPlayer2Ref")
  booking             Booking?
  reverts             TournamentMatchRevert[]

  @@unique([tournamentId, bracketPosition])
  @@index([matchKind])
  @@map("tournament_matches")
  @@schema("klub")
}

model TournamentMatchRevert {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentMatchId String    @map("tournament_match_id") @db.Uuid

  revertedById      String    @map("reverted_by_id") @db.Uuid
  revertedAt        DateTime  @default(now()) @map("reverted_at") @db.Timestamptz
  reason            String?

  previousState     Json      @map("previous_state")
  // Snapshot completo:
  // {
  //   winnerId, matchResultId, status, completedAt,
  //   ratingDeltas: [{ userId, ratingBefore, ratingAfter, delta, toRevert }],
  //   nextMatchAffected?: { id, slot, hadCompleted }
  // }

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tournamentMatch   TournamentMatch @relation(fields: [tournamentMatchId], references: [id])

  @@index([tournamentMatchId])
  @@index([revertedAt])
  @@map("tournament_match_reverts")
  @@schema("klub")
}

model TournamentEntry {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId      String    @map("tournament_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  categoryId        String?   @map("category_id") @db.Uuid

  status            String    @default("pending_seeding")
  finalPosition     String?   @map("final_position")

  ratingAtEntry     Int?      @map("rating_at_entry")

  categorySource    String    @default("auto") @map("category_source")
  isWildCard        Boolean   @default(false) @map("is_wild_card")

  registeredAt      DateTime  @default(now()) @map("registered_at") @db.Timestamptz
  approvedAt        DateTime? @map("approved_at") @db.Timestamptz
  approvedById      String?   @map("approved_by_id") @db.Uuid
  seededAt          DateTime? @map("seeded_at") @db.Timestamptz
  movedById         String?   @map("moved_by_id") @db.Uuid
  withdrawnAt       DateTime? @map("withdrawn_at") @db.Timestamptz

  tournament        Tournament         @relation(fields: [tournamentId], references: [id])
  user              User               @relation("TournamentEntries", fields: [userId], references: [id])
  category          TournamentCategory? @relation(fields: [categoryId], references: [id])

  @@unique([tournamentId, userId])
  @@map("tournament_entries")
  @@schema("klub")
}

// ═══════════════════════════════════════════════════════════════
// SPORTS — catálogo global da plataforma
// ═══════════════════════════════════════════════════════════════

model SportCatalog {
  code          String    @id
  name          String
  description   String?
  playType      String    @default("both") @map("play_type")
  minPlayers    Int       @default(2) @map("min_players")
  maxPlayers    Int       @default(4) @map("max_players")
  active        Boolean   @default(true)
  sortOrder     Int       @default(0) @map("sort_order")
  iconUrl       String?   @map("icon_url")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  klubProfiles  KlubSportProfile[]

  @@map("catalog")
  @@schema("sports")
}

model RatingEngine {
  code          String    @id
  name          String
  description   String?
  configSchema  Json      @map("config_schema")
  defaultConfig Json      @map("default_config")
  active        Boolean   @default(true)

  @@map("rating_engines")
  @@schema("sports")
}

model KlubRequest {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  type             String    @default("sports_club")
  city             String
  state            String
  contactName      String    @map("contact_name")
  contactEmail     String    @map("contact_email")
  contactPhone     String?   @map("contact_phone")
  sportCodes       String[]  @map("sport_codes")
  estimatedMembers Int?      @map("estimated_members")
  message          String?
  status           String    @default("pending")
  // pending | approved | rejected | converted
  convertedKlubId  String?   @map("converted_klub_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz
  reviewedById     String?   @map("reviewed_by_id") @db.Uuid

  @@map("klub_requests")
  @@schema("klub")
}

model KlubMedia {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId    String   @map("klub_id") @db.Uuid
  type      String
  // photo | video | cover | logo
  url       String
  order     Int      @default(0)
  caption   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  klub  Klub  @relation(fields: [klubId], references: [id])

  @@map("klub_media")
  @@schema("klub")
}

// ═══════════════════════════════════════════════════════════════
// SPACE
// ═══════════════════════════════════════════════════════════════

model Space {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId      String    @map("klub_id") @db.Uuid
  name        String
  // ex: "Quadra 1", "Quadra Central", "Sala A"
  type        String    @default("court")
  // court | room | pool | field | other
  sportCode   String?   @map("sport_code")
  // tennis | padel | squash | beach_tennis | null (pra spaces não-esportivos)
  surface     String?
  // clay | hard | grass | synthetic | carpet | null
  indoor      Boolean   @default(false)
  hasLighting Boolean   @default(false) @map("has_lighting")
  maxPlayers  Int       @default(4)     @map("max_players")
  description String?
  amenities   Json      @default("{}")
  status      String    @default("active")
  // active | maintenance | inactive

  slotGranularityMinutes     Int      @default(30) @map("slot_granularity_minutes")
  // 15-180, múltiplo de 15 (validação Zod + check constraint)
  slotDefaultDurationMinutes Int      @default(60) @map("slot_default_duration_minutes")
  bookingActive              Boolean  @default(true) @map("booking_active")

  hourBands                  Json     @default("[]") @map("hour_bands")
  // [{ type: 'off_peak'|'regular'|'prime', startHour, endHour, daysOfWeek,
  //    durationByMatchType: { singles?, doubles? } }]
  allowedMatchTypes          Json     @default("[\"singles\",\"doubles\"]") @map("allowed_match_types")
  // ['singles', 'doubles'] | ['singles'] | ['doubles']

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  tournamentMatches TournamentMatch[]
  bookings          Booking[]
  bookingSeries     BookingSeries[]

  @@map("spaces")
  @@schema("space")
}

// ═══════════════════════════════════════════════════════════════
// BOOKING
// ═══════════════════════════════════════════════════════════════

model Booking {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId          String    @map("klub_id") @db.Uuid
  spaceId         String    @map("space_id") @db.Uuid

  startsAt        DateTime  @map("starts_at") @db.Timestamptz
  endsAt          DateTime? @map("ends_at") @db.Timestamptz

  bookingType     String    @default("player_match") @map("booking_type")
  // 'player_match' | 'player_free_play' | 'maintenance' | 'weather_closed' | 'staff_blocked'

  creationMode    String    @map("creation_mode")
  // 'direct' | 'staff_approval' | 'staff_assisted'

  status          String    @default("pending") @map("status")
  // 'pending' | 'confirmed' | 'cancelled' | 'no_show' | 'completed'

  primaryPlayerId String?   @map("primary_player_id") @db.Uuid
  otherPlayers    Json      @default("[]") @map("other_players")

  matchType       String?   @map("match_type")
  // 'singles' | 'doubles' | null (null pra blocos operacionais e bookings 10A/10B legados)

  responsibleMemberId String?  @map("responsible_member_id") @db.Uuid
  // FK pra User. Nullable. Default = primaryPlayerId quando primary eh member.
  // Em members_only sem primary member, este campo eh obrigatorio.
  responsibleMember   User?    @relation("ResponsibleMember", fields: [responsibleMemberId], references: [id])

  extensions      Json      @default("[]") @map("extensions")
  // [{ id, extendedFrom, extendedTo, mode, status, requestedById, requestedAt, decidedById?, decidedAt?, decisionReason? }]

  tournamentMatchId String?  @unique @map("tournament_match_id") @db.Uuid

  bookingSeriesId String?   @map("booking_series_id") @db.Uuid
  autoCancelledByBookingId String? @map("auto_cancelled_by_booking_id") @db.Uuid

  createdById     String?   @map("created_by_id") @db.Uuid
  approvedById    String?   @map("approved_by_id") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz
  rejectedById    String?   @map("rejected_by_id") @db.Uuid
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamptz
  rejectionReason String?   @map("rejection_reason")

  cancelledById   String?   @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz
  cancellationReason String? @map("cancellation_reason")

  notes           String?

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  space           Space     @relation(fields: [spaceId], references: [id])
  tournamentMatch TournamentMatch? @relation(fields: [tournamentMatchId], references: [id])
  bookingSeries   BookingSeries? @relation(fields: [bookingSeriesId], references: [id])
  autoCancelledBy Booking?  @relation("AutoCancellation", fields: [autoCancelledByBookingId], references: [id])
  cancelledBookings Booking[] @relation("AutoCancellation")

  @@index([klubId, startsAt])
  @@index([spaceId, startsAt])
  @@index([primaryPlayerId, startsAt])
  @@index([status])
  @@index([matchType])
  @@map("bookings")
  @@schema("booking")
}

model BookingSeries {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId          String    @map("klub_id") @db.Uuid
  spaceId         String    @map("space_id") @db.Uuid

  frequency       String
  interval        Int       @default(1)
  daysOfWeek      Json      @default("[]") @map("days_of_week")

  startsOn        DateTime  @map("starts_on") @db.Timestamptz
  endsOn          DateTime  @map("ends_on") @db.Timestamptz

  durationMinutes Int       @map("duration_minutes")
  startHour       Int       @map("start_hour")
  startMinute     Int       @default(0) @map("start_minute")

  bookingType     String    @default("player_match") @map("booking_type")

  primaryPlayerId String?   @map("primary_player_id") @db.Uuid
  otherPlayers    Json      @default("[]") @map("other_players")

  status          String    @default("active")

  createdById     String    @map("created_by_id") @db.Uuid
  cancelledById   String?   @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz
  cancellationReason String? @map("cancellation_reason")
  notes           String?

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  space           Space     @relation(fields: [spaceId], references: [id])
  bookings        Booking[]

  @@index([klubId, startsOn])
  @@index([spaceId, startsOn])
  @@index([primaryPlayerId])
  @@map("booking_series")
  @@schema("booking")
}
