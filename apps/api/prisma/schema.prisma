  maxRatingExpected Int?    @map("max_rating_expected")

  pointsSchemaId    String  @map("points_schema_id") @db.Uuid

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt      @map("updated_at") @db.Timestamptz
  createdById       String?  @map("created_by_id") @db.Uuid
  updatedById       String?  @map("updated_by_id") @db.Uuid

  tournament   Tournament          @relation(fields: [tournamentId], references: [id])
  pointsSchema RankingPointsSchema @relation(fields: [pointsSchemaId], references: [id])
  entries      TournamentEntry[]
  matches      TournamentMatch[]
  createdBy    User? @relation("TournamentCategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy    User? @relation("TournamentCategoryUpdatedBy", fields: [updatedById], references: [id])

  @@unique([tournamentId, name])
  @@unique([tournamentId, order])
  @@map("tournament_categories")
  @@schema("klub")
}

model TournamentMatch {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentId        String    @map("tournament_id") @db.Uuid
  categoryId          String    @map("category_id") @db.Uuid

  phase               String
  round               Int
  bracketPosition     String    @map("bracket_position")
  slotTop             Int       @map("slot_top")
  slotBottom          Int       @map("slot_bottom")

  player1Id           String?   @map("player1_id") @db.Uuid
  player2Id           String?   @map("player2_id") @db.Uuid

  seed1               Int?
  seed2               Int?
  isBye               Boolean   @default(false) @map("is_bye")

  nextMatchId         String?   @map("next_match_id") @db.Uuid
  nextMatchSlot       String?   @map("next_match_slot")

  status              TournamentMatchStatus @default(pending)
  winnerId            String?               @map("winner_id") @db.Uuid
  matchResultId       String?               @map("match_result_id") @db.Uuid @unique

  matchKind                     TournamentMatchKind @default(main) @map("match_kind")
  prequalifierFrontierUpper     String?   @map("prequalifier_frontier_upper")
  prequalifierFrontierLower     String?   @map("prequalifier_frontier_lower")
  prequalifierPairIndex         Int?      @map("prequalifier_pair_index")

  tbdPlayer1Source              String?   @map("tbd_player1_source")
  tbdPlayer1PrequalifierMatchRef String?  @map("tbd_player1_prequalifier_ref") @db.Uuid
  tbdPlayer1Label               String?   @map("tbd_player1_label")

  tbdPlayer2Source              String?   @map("tbd_player2_source")
  tbdPlayer2PrequalifierMatchRef String?  @map("tbd_player2_prequalifier_ref") @db.Uuid
  tbdPlayer2Label               String?   @map("tbd_player2_label")

  spaceId             String?   @map("space_id") @db.Uuid
  scheduleWarning     String?   @map("schedule_warning")

  scheduledFor        DateTime? @map("scheduled_for") @db.Timestamptz
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  updatedById         String?   @map("updated_by_id") @db.Uuid

  tournament          Tournament          @relation(fields: [tournamentId], references: [id])
  category            TournamentCategory  @relation(fields: [categoryId], references: [id])
  space               Space?              @relation(fields: [spaceId], references: [id])
  nextMatch           TournamentMatch?    @relation("BracketProgression", fields: [nextMatchId], references: [id])
  previousMatches     TournamentMatch[]   @relation("BracketProgression")
  matchResult         MatchResult?        @relation("TournamentMatchResult", fields: [matchResultId], references: [id])
  tbdPlayer1Prequalifier TournamentMatch? @relation("TbdPlayer1Ref", fields: [tbdPlayer1PrequalifierMatchRef], references: [id])
  tbdPlayer1DependentMatches TournamentMatch[] @relation("TbdPlayer1Ref")
  tbdPlayer2Prequalifier TournamentMatch? @relation("TbdPlayer2Ref", fields: [tbdPlayer2PrequalifierMatchRef], references: [id])
  tbdPlayer2DependentMatches TournamentMatch[] @relation("TbdPlayer2Ref")
  booking             Booking?
  reverts             TournamentMatchRevert[]
  updatedBy           User? @relation("TournamentMatchUpdatedBy", fields: [updatedById], references: [id])

  @@unique([tournamentId, bracketPosition])
  @@index([matchKind])
  @@map("tournament_matches")
  @@schema("klub")
}

model TournamentMatchRevert {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tournamentMatchId String    @map("tournament_match_id") @db.Uuid

  revertedById      String    @map("reverted_by_id") @db.Uuid
  revertedAt        DateTime  @default(now()) @map("reverted_at") @db.Timestamptz
  reason            String?

  previousState     Json      @map("previous_state")
  // Snapshot completo:
  // {
  //   winnerId, matchResultId, status, completedAt,
