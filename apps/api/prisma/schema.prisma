// ═══════════════════════════════════════════════════════════════
// BOOKING
// ═══════════════════════════════════════════════════════════════

model Booking {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId          String    @map("klub_id") @db.Uuid
  spaceId         String    @map("space_id") @db.Uuid

  startsAt        DateTime  @map("starts_at") @db.Timestamptz
  endsAt          DateTime  @map("ends_at") @db.Timestamptz

  bookingType     BookingType         @default(player_match) @map("booking_type")

  creationMode    BookingCreationMode @map("creation_mode")

  status          BookingStatus       @default(pending) @map("status")

  primaryPlayerId String?   @map("primary_player_id") @db.Uuid
  otherPlayers    Json      @default("[]") @map("other_players")

  matchType       MatchType? @map("match_type")

  responsibleMemberId String?  @map("responsible_member_id") @db.Uuid
  responsibleMember   User?    @relation("ResponsibleMember", fields: [responsibleMemberId], references: [id])

  extensions      Json      @default("[]") @map("extensions")
  // [{ id, extendedFrom, extendedTo, mode, status, requestedById, requestedAt, decidedById?, decidedAt?, decisionReason? }]

  tournamentMatchId String?  @unique @map("tournament_match_id") @db.Uuid

  bookingSeriesId String?   @map("booking_series_id") @db.Uuid
  autoCancelledByBookingId String? @map("auto_cancelled_by_booking_id") @db.Uuid

  createdById     String?   @map("created_by_id") @db.Uuid
  approvedById    String?   @map("approved_by_id") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz
  rejectedById    String?   @map("rejected_by_id") @db.Uuid
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamptz
  rejectionReason String?   @map("rejection_reason")

  cancelledById   String?   @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz
  cancellationReason String? @map("cancellation_reason")

  // Sprint Polish PR-A — timestamp do envio do lembrete 24h antes.
  // Cron escaneia bookings em [now+23h, now+25h] com este campo NULL.
  reminderSentAt  DateTime? @map("reminder_sent_at") @db.Timestamptz

  notes           String?

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  updatedById     String?   @map("updated_by_id") @db.Uuid

  klub            Klub      @relation("BookingKlub", fields: [klubId], references: [id])
  space           Space     @relation(fields: [spaceId], references: [id])
  tournamentMatch TournamentMatch? @relation(fields: [tournamentMatchId], references: [id])
  bookingSeries   BookingSeries? @relation(fields: [bookingSeriesId], references: [id])
  autoCancelledBy Booking?  @relation("AutoCancellation", fields: [autoCancelledByBookingId], references: [id])
  cancelledBookings Booking[] @relation("AutoCancellation")
  primaryPlayer   User?     @relation("BookingPrimaryPlayer", fields: [primaryPlayerId], references: [id])
  createdBy       User?     @relation("BookingCreatedBy", fields: [createdById], references: [id])
  approvedBy      User?     @relation("BookingApprovedBy", fields: [approvedById], references: [id])
  rejectedBy      User?     @relation("BookingRejectedBy", fields: [rejectedById], references: [id])
  cancelledBy     User?     @relation("BookingCancelledBy", fields: [cancelledById], references: [id])
  updatedBy       User?     @relation("BookingUpdatedBy", fields: [updatedById], references: [id])

  @@index([klubId, startsAt])
  @@index([spaceId, startsAt])
  @@index([primaryPlayerId, startsAt])
  @@index([status])
  @@index([matchType])
  @@map("bookings")
  @@schema("booking")
}

model BookingSeries {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  klubId          String    @map("klub_id") @db.Uuid
  spaceId         String    @map("space_id") @db.Uuid

  frequency       BookingSeriesFrequency
  interval        Int       @default(1)
  daysOfWeek      Json      @default("[]") @map("days_of_week")

  startsOn        DateTime  @map("starts_on") @db.Timestamptz
  endsOn          DateTime  @map("ends_on") @db.Timestamptz

  durationMinutes Int       @map("duration_minutes")
  startHour       Int       @map("start_hour")
  startMinute     Int       @default(0) @map("start_minute")

  bookingType     BookingType @default(player_match) @map("booking_type")

  primaryPlayerId String?   @map("primary_player_id") @db.Uuid
  otherPlayers    Json      @default("[]") @map("other_players")

  status          BookingSeriesStatus @default(active)

  createdById     String    @map("created_by_id") @db.Uuid
  cancelledById   String?   @map("cancelled_by_id") @db.Uuid
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz
  cancellationReason String? @map("cancellation_reason")
  notes           String?

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt      @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  updatedById     String?   @map("updated_by_id") @db.Uuid

  space          Space     @relation(fields: [spaceId], references: [id])
  bookings       Booking[]
  primaryPlayer  User?     @relation("BookingSeriesPrimaryPlayer", fields: [primaryPlayerId], references: [id])
  createdBy      User      @relation("BookingSeriesCreatedBy", fields: [createdById], references: [id])
  cancelledBy    User?     @relation("BookingSeriesCancelledBy", fields: [cancelledById], references: [id])
  updatedBy      User?     @relation("BookingSeriesUpdatedBy", fields: [updatedById], references: [id])

  @@index([klubId, startsOn])
  @@index([spaceId, startsOn])
  @@index([primaryPlayerId])
  @@map("booking_series")
  @@schema("booking")
}

