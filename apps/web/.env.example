NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=draftklub-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=draftklub-dev
NEXT_PUBLIC_FIREBASE_APP_ID=1:598839404621:web:defb81d47aa0839991d404
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=draftklub-dev.firebasestorage.app
