# URL base do site (usada em metadata e openGraph)
NEXT_PUBLIC_WEB_URL=http://localhost:3001

# URL da API DraftKlub (apps/api roda na porta 3000 por default)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Firebase Web SDK config (PUBLIC — vai pro bundle JS do browser) ──────
# Estes valores NÃO são secretos por design (vão pro bundle do navegador).
# Segurança real vem das Security Rules + Authorized Domains + App Check.
# Mesmo assim, mantemos placeholders aqui pra não identificar o projeto
# específico em commits versionados — secret scanners flagram o pattern
# AIza... e o alerta polui CI. Valores reais ficam em .env.local (gitignored).
#
# Recuperados de: Firebase Console → Project Settings → Your apps → Web
# (ou via REST: GET firebase.googleapis.com/v1beta1/projects/<id>/webApps/<appId>/config)
NEXT_PUBLIC_FIREBASE_API_KEY=<get-from-firebase-console>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<your-project>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<your-project>
NEXT_PUBLIC_FIREBASE_APP_ID=<get-from-firebase-console>
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=<your-project>.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<get-from-firebase-console>
